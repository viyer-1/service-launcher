# Service Launcher Configuration Example
# Copy this file to .env and modify as needed

# API Key for authentication (Optional)
# If set, all requests must include 'X-API-Key' header
# APP_API_KEY=your-secret-api-key-here

# Port to run the server on
SERVICE_LAUNCHER_PORT=5000

# Allowed paths for the file/folder browser (comma-separated)
# Security: Users will only be able to browse within these paths
# Default: current directory and user home directory
# ALLOWED_BROWSE_PATHS=/data,/mnt/usb,/home/user

# Default directory shown when opening the file browser
# DEFAULT_BROWSE_PATH=/data

# Memory threshold for switching to file-based output (in bytes)
# Default: 5MB (5242880)
# OUTPUT_MEMORY_THRESHOLD=5242880

# File to track web app client sessions
# WEB_APP_CLIENTS_FILE=web_app_clients.json
