# Service Launcher — Example Configuration
#
# This file defines all scripts that can be executed through the web interface.
# Copy this file to scripts_config.yaml and customise it.
#
# The web UI also has a built-in script editor (gear icon, top-right) if you
# prefer not to edit YAML directly.

scripts:

  # ─────────────────────────────────────────────────────────────────────────
  # 1. Simple script — no parameters
  # ─────────────────────────────────────────────────────────────────────────
  - id: system-uptime
    name: System Uptime
    description: Shows how long the system has been running
    category: System
    command: "uptime -p"

  # ─────────────────────────────────────────────────────────────────────────
  # 2. Script with parameters
  # ─────────────────────────────────────────────────────────────────────────
  - id: ping-host
    name: Ping Host
    description: Ping a host to check if it's reachable
    category: Tools
    command: "ping -c 4"
    parameters:
      - name: ""              # empty = positional argument (appended after command)
        label: Hostname or IP
        type: text
        required: true
        placeholder: "google.com"
        description: The host to ping

  # ─────────────────────────────────────────────────────────────────────────
  # 3. Web application — shows an "Open" button after starting
  # ─────────────────────────────────────────────────────────────────────────
  - id: example-webapp
    name: Example Web App
    description: Start a local web server (Python)
    category: Development
    command: "python3 ./examples/example_webapp.py"
    parameters:
      - name: "--port"
        label: Port
        type: number
        required: false
        placeholder: "8080"
    url: "http://localhost:8080"   # auto-replaced with server IP for remote access

  # ─────────────────────────────────────────────────────────────────────────
  # 4. File-based processing
  # ─────────────────────────────────────────────────────────────────────────
  - id: log-viewer
    name: Log Viewer
    description: Read the end of a specific log file
    category: System
    command: "tail -n"
    parameters:
      - name: ""
        label: Lines
        type: number
        required: true
        placeholder: "50"
      - name: ""
        label: Log File
        type: file-browser
        required: true
        placeholder: "/var/log/syslog"

# ─────────────────────────────────────────────────────────────────────────
# Categories (affects card colour in the UI)
#   System      → Purple
#   Development → Blue
#   Database    → Green
#   Web         → Orange
#   Multimedia  → Pink
#   AI          → Teal
#   Tools       → Gray (default for anything else)
# ─────────────────────────────────────────────────────────────────────────

